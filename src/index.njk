<!-- WRITING -->
<section class="section" id="writing">
  <div class="section-label">Writing</div>
  <h2>Recent Posts</h2>
  {% if collections.posts.length > 0 %}
  <ul class="writing-list">
    {% for post in collections.posts | limit(5) %}
    <li class="writing-item">
      <span class="writing-date">{{ post.date | dateFormat }}</span>
      <span class="writing-title"><a href="{{ post.url }}">{{ post.data.title }}</a></span>
    </li>
    {% endfor %}
  </ul>
  {% else %}
  <ul class="writing-list">
    <li class="writing-item">
      <span class="writing-date">Coming soon</span>
      <span class="writing-title" style="color:var(--muted);">Posts loading&hellip;</span>
    </li>
  </ul>
  {% endif %}
  <a href="/blog/" class="btn btn-outline">All posts &rarr;</a>
</section>

