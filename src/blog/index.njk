---
layout: base.njk
title: Blog
pagination:
  data: collections.posts
  size: 10
  alias: posts
  reverse: true
permalink: "blog/{% if pagination.pageNumber > 0 %}page-{{ pagination.pageNumber + 1 }}/{% endif %}index.html"
---
<div class="blog-container">
  <div class="page-title">Blog &mdash; Daniel Newcome</div>

  {% if posts.length > 0 %}
  <ul class="post-list">
    {% for post in posts %}
    <li class="post-item">
      <div class="post-meta">{{ post.date | dateFormat }}</div>
      <div class="post-title"><a href="{{ post.url }}">{{ post.data.title }}</a></div>
      {% if post.templateContent %}
      <div class="post-excerpt">{{ post.templateContent | excerpt }}</div>
      {% endif %}
      {% if post.data.tags %}
      <div class="post-tags">
        {% for tag in post.data.tags %}
          {% if tag != 'posts' %}
            <span class="tag">{{ tag }}</span>
          {% endif %}
        {% endfor %}
      </div>
      {% endif %}
    </li>
    {% endfor %}
  </ul>

  <div class="pagination">
    {% if pagination.href.previous %}
      <a href="{{ pagination.href.previous }}">&larr; Newer</a>
    {% else %}
      <span></span>
    {% endif %}
    <span class="spacer"></span>
    <span class="page-info">
      Page {{ pagination.pageNumber + 1 }} of {{ pagination.pages.length }}
    </span>
    <span class="spacer"></span>
    {% if pagination.href.next %}
      <a href="{{ pagination.href.next }}">Older &rarr;</a>
    {% else %}
      <span></span>
    {% endif %}
  </div>

  {% else %}
  <p style="color:var(--muted); font-size:0.85rem;">No posts yet. Check back soon.</p>
  {% endif %}
</div>
