<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — Resume</title>
  <style>
    @page {
      size: letter;
      margin: 0.75in 0.8in;
    }

    :root {
      --accent: #000;
      --muted: #555;
      --border: #ccc;
      --text: #111;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Courier New', Courier, monospace;
      font-size: 10pt;
      color: var(--text);
      line-height: 1.5;
      background: #fff;
    }

    a { color: var(--text); text-decoration: none; }

    /* HEADER */
    .resume-header {
      margin-bottom: 1.4em;
      padding-bottom: 0.75em;
      border-bottom: 2px solid #000;
    }

    .resume-name {
      font-size: 22pt;
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1;
      margin-bottom: 0.3em;
    }

    .resume-contact {
      font-size: 8.5pt;
      color: var(--muted);
      letter-spacing: 0.04em;
      display: flex;
      flex-wrap: wrap;
      gap: 0 1.5em;
    }

    /* SECTIONS */
    .resume-section {
      margin-bottom: 1.2em;
    }

    .resume-section h2 {
      font-size: 8pt;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      border-bottom: 1px solid var(--border);
      padding-bottom: 0.2em;
      margin-bottom: 0.7em;
    }

    /* ENTRIES (jobs, projects) */
    .entry {
      margin-bottom: 0.9em;
    }

    .entry-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 1em;
    }

    .entry-title {
      font-size: 10pt;
      font-weight: 700;
    }

    .entry-date {
      font-size: 8.5pt;
      color: var(--muted);
      white-space: nowrap;
      flex-shrink: 0;
    }

    .entry-org {
      font-size: 9pt;
      color: var(--muted);
      margin-bottom: 0.3em;
    }

    .entry ul {
      margin-left: 1.2em;
      margin-top: 0.25em;
    }

    .entry li {
      font-size: 9.5pt;
      margin-bottom: 0.15em;
      line-height: 1.4;
    }

    .entry p {
      font-size: 9.5pt;
      line-height: 1.5;
      margin-top: 0.25em;
    }

    /* SKILLS */
    .skills-grid {
      display: grid;
      grid-template-columns: 110px 1fr;
      gap: 0.3em 1em;
    }

    .skills-label {
      font-size: 8.5pt;
      color: var(--muted);
      padding-top: 0.1em;
    }

    .skills-value {
      font-size: 9.5pt;
    }

    /* page break hints */
    .entry { page-break-inside: avoid; }
    .resume-section { page-break-inside: avoid; }
  </style>
</head>
<body>
  {{ content | safe }}
</body>
</html>
