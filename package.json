{
  "name": "dnuke-com",
  "version": "1.0.0",
  "description": "dnuke.com — Daniel Newcome personal site",
  "scripts": {
    "sync": "bash scripts/sync-projects.sh",
    "build": "bash scripts/sync-projects.sh && eleventy",
    "serve": "bash scripts/sync-projects.sh && eleventy --serve",
    "watch": "eleventy --watch",
    "pdf": "eleventy && node scripts/pdf.js",
    "scrape-resume": "node scripts/scrape-linkedin.js"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "puppeteer": "^24.40.0"
  }
}
